@model IEnumerable<PhotoPortfolia.Models.Album>

@{
    ViewData["Title"] = "Portfolio";
}

<div class="container mt-4">
    <h1 class="display-4 text-center">My Photography Portfolio</h1>
    <p class="text-center text-muted">Explore my work through different categories.</p>

    @if (User.Identity.IsAuthenticated)
    {
        <div class="d-flex justify-content-end mb-4">
            <a asp-action="Create" class="btn btn-primary shadow-sm">+ Create New Album</a>
        </div>
    }

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@item.Title</h5>
                        <h6 class="card-subtitle mb-2 text-muted">@item.Category.Name</h6>
                        <p class="card-text flex-grow-1">@item.Description</p>

                        <div class="mt-3">
                            <div class="d-grid mb-2">
                                <a asp-controller="Photos"
                                   asp-action="AlbumPhotos"
                                   asp-route-albumId="@item.Id"
                                   class="btn btn-dark">View Photos</a>
                            </div>

                            @if (User.Identity.IsAuthenticated)
                            {
                                <div class="btn-group w-100">
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-secondary">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-danger">Delete</a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
