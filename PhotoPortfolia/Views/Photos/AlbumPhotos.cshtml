@model IEnumerable<PhotoPortfolia.ViewModels.PhotoViewModel>

@{
	ViewData["Title"] = ViewBag.AlbumTitle ?? "Album Photos";
}

<div class="container mt-4">
	<nav aria-label="breadcrumb">
		<ol class="breadcrumb">
			<li class="breadcrumb-item"><a asp-controller="Albums" asp-action="Index">Portfolio</a></li>
			<li class="breadcrumb-item active">@ViewBag.AlbumTitle</li>
		</ol>
	</nav>

	<div class="d-flex justify-content-between align-items-end mb-4">
		<div>
			<h1 class="display-4">@ViewBag.AlbumTitle</h1>
			<p class="lead text-muted">Explore the collection of high-quality photography.</p>
		</div>

		<div class="w-25">
			<form asp-action="AlbumPhotos" method="get" class="d-flex shadow-sm">
				<input type="hidden" name="albumId" value="@ViewBag.AlbumId" />
				<input type="text" name="searchTerm" value="@ViewBag.SearchTerm"
					   class="form-control form-control-sm me-1" placeholder="Search by title..." />
				<button type="submit" class="btn btn-primary btn-sm px-3">
					<i class="fas fa-search"></i> Search
				</button>
			</form>
		</div>
	</div>

	<hr />

	<div class="row min-vh-50">
		@if (!Model.Any())
		{
			<div class="col-12 text-center py-5">
				<div class="alert alert-light border shadow-sm">
					<i class="fas fa-camera-retro fa-3x mb-3 text-muted"></i>
					<p class="text-muted mb-0">No photos found matching your criteria in this album.</p>
					<a asp-action="AlbumPhotos" asp-route-albumId="@ViewBag.AlbumId" class="btn btn-link">Clear search</a>
				</div>
			</div>
		}
		else
		{
			@foreach (var photo in Model)
			{
				<div class="col-lg-4 col-md-6 mb-4">
					<div class="card h-100 shadow-sm border-0 photo-card">
						<img src="@photo.ImageUrl" class="card-img-top rounded shadow"
							 alt="@photo.Title" style="height: 250px; object-fit: cover;">
						<div class="card-body px-1">
							<h5 class="card-title h6 fw-bold">@photo.Title</h5>
							@if (!string.IsNullOrEmpty(photo.Description))
							{
								<p class="card-text small text-muted">@photo.Description</p>
							}
						</div>
					</div>
				</div>
			}
		}
	</div>

	@if (ViewBag.TotalPages > 1)
	{
		<nav class="mt-5">
			<ul class="pagination justify-content-center shadow-sm">
				<li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
					<a class="page-link" asp-route-albumId="@ViewBag.AlbumId"
					   asp-route-page="@(ViewBag.CurrentPage - 1)"
					   asp-route-searchTerm="@ViewBag.SearchTerm">Previous</a>
				</li>

				@for (int i = 1; i <= ViewBag.TotalPages; i++)
				{
					<li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
						<a class="page-link" asp-route-albumId="@ViewBag.AlbumId"
						   asp-route-page="@i"
						   asp-route-searchTerm="@ViewBag.SearchTerm">@i</a>
					</li>
				}

				<li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
					<a class="page-link" asp-route-albumId="@ViewBag.AlbumId"
					   asp-route-page="@(ViewBag.CurrentPage + 1)"
					   asp-route-searchTerm="@ViewBag.SearchTerm">Next</a>
				</li>
			</ul>
		</nav>
	}

	<hr class="mt-5" />

	<div class="mt-4">
		<partial name="_CommentPartial" model="ViewBag.AlbumId" />
	</div>
</div>

<style>
	.photo-card {
		transition: transform 0.3s;
	}

		.photo-card:hover {
			transform: translateY(-5px);
		}

	.pagination .page-link {
		color: #333;
		border-radius: 5px;
		margin: 0 2px;
	}

	.pagination .page-item.active .page-link {
		background-color: #0d6efd;
		border-color: #0d6efd;
	}
</style>